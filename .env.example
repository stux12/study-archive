# Notion integration secret (never commit the real value)
NOTION_TOKEN=secret_xxx
# Either value can be used. Database ID is easier: it is the 32-character ID in
# your Notion database URL. The sync script finds its data source automatically.
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Change these only if your Notion property names differ.
NOTION_TITLE_PROPERTY=제목
NOTION_STATUS_PROPERTY=상태
NOTION_TAGS_PROPERTY=태그
NOTION_CATEGORY_PROPERTY=카테고리
NOTION_SLUG_PROPERTY=슬러그
NOTION_SUMMARY_PROPERTY=요약
NOTION_DATE_PROPERTY=학습일
