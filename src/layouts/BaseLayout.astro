---
interface Props { title?: string; description?: string; type?: 'website' | 'article'; image?: string }
const { title = '공부 아카이브', description = '배우고 정리한 내용을 기록합니다.', type = 'website', image } = Astro.props;

const siteName = '공부 아카이브';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image ?? `${base}og.png`, Astro.site);
const rssURL = `${base}rss.xml`;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0f172a" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="alternate" type="application/rss+xml" title={siteName} href={rssURL} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={import.meta.env.BASE_URL}>공부 아카이브</a>
      <span>Notion → 검수 → Publish</span>
    </header>
    <main><slot /></main>
    <footer>
      <span>꾸준히 배우고, 이해한 만큼 기록합니다.</span>
      <a href={rssURL}>RSS</a>
    </footer>
  </body>
</html>
<style is:global>
  :root { font-family: Pretendard, "Noto Sans KR", system-ui, sans-serif; color: #1f2937; background: #f8fafc; }
  * { box-sizing: border-box; }
  body { margin: 0; line-height: 1.7; }
  .site-header, main, footer { max-width: 920px; margin: auto; padding-inline: 24px; }
  .site-header { min-height: 76px; display: flex; align-items: center; justify-content: space-between; color: #64748b; font-size: .9rem; }
  .brand { color: #0f172a; font-size: 1.15rem; font-weight: 800; text-decoration: none; }
  main { padding-block: 48px 72px; }
  footer { border-top: 1px solid #e2e8f0; padding-block: 28px; color: #64748b; font-size: .9rem; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  footer a { color: #64748b; text-decoration: none; font-weight: 700; }
  footer a:hover { color: #2563eb; }
  a { color: #2563eb; }
  h1, h2, h3 { line-height: 1.3; color: #0f172a; }
  code { background: #e2e8f0; border-radius: 4px; padding: .1em .3em; font-family: "Cascadia Code", Consolas, monospace; font-size: .9em; }
  pre { margin: 20px 0; padding: 20px; overflow-x: auto; border: 1px solid #1e293b; border-radius: 12px; background: #0f172a; color: #e2e8f0; box-shadow: 0 12px 24px rgb(15 23 42 / .14); line-height: 1.65; }
  pre code { background: transparent; padding: 0; color: inherit; font-size: .9rem; }
  blockquote { margin: 20px 0; padding: 4px 18px; border-left: 4px solid #60a5fa; color: #475569; background: #eff6ff; }
  table { width: 100%; border-collapse: collapse; margin: 20px 0; }
  th, td { padding: 10px; border: 1px solid #cbd5e1; text-align: left; }
</style>
