---
interface Props { title?: string; description?: string; type?: 'website' | 'article'; image?: string }
const { title = '공부 아카이브', description = '배우고 정리한 내용을 기록합니다.', type = 'website', image } = Astro.props;

const siteName = '공부 아카이브';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image ?? `${base}og.png`, Astro.site);
const rssURL = `${base}rss.xml`;
const fontHref = 'https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendard-variable-dynamic-subset.min.css';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0a0f1a" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preload" as="style" href={fontHref} onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="alternate" type="application/rss+xml" title={siteName} href={rssURL} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />

    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="glow" aria-hidden="true"></div>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={base}>
          <svg class="brand-mark" viewBox="0 0 24 24" width="23" height="23" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 5.4c3-.5 6-.3 9 1 3-1.3 6-1.5 9-1v12.7c-3-.5-6-.3-9 1-3-1.3-6-1.5-9-1z" />
            <path d="M12 6.4V20" />
          </svg>
          <span class="brand-text">공부 아카이브</span>
        </a>
        <nav class="nav">
          <span class="nav-tag">Notion에 공부 정리 → 검수 → AI Publish</span>
          <a class="icon-btn" href={rssURL} title="RSS 구독" aria-label="RSS 구독">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <button class="icon-btn" id="theme-toggle" type="button" title="테마 전환" aria-label="테마 전환">
            <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.3 6.3 0 0 0 10.5 10.5Z"/></svg>
          </button>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer>
      <span>꾸준히 배우고, 이해한 만큼 기록합니다.</span>
      <div class="footer-right">
        <span class="visits" id="visits" hidden>방문자 <b id="visit-count"></b></span>
        <a href={rssURL}>RSS</a>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>

    <script>
      // Mermaid 다이어그램은 있는 페이지에서만 동적 로드(코드 분할)
      (async () => {
        const blocks = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
        if (!blocks.length) return;
        const { default: mermaid } = await import('mermaid');
        blocks.forEach((el) => { el.dataset.src = el.textContent || ''; });
        const themeName = () => (document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default');
        const render = async () => {
          mermaid.initialize({ startOnLoad: false, theme: themeName(), securityLevel: 'strict', fontFamily: 'inherit' });
          for (const el of blocks) { el.removeAttribute('data-processed'); el.innerHTML = el.dataset.src || ''; }
          try { await mermaid.run({ nodes: blocks }); } catch (e) { console.error('mermaid', e); }
        };
        await render();
        let timer = 0;
        new MutationObserver(() => { clearTimeout(timer); timer = window.setTimeout(render, 80); })
          .observe(document.documentElement, { attributeFilter: ['data-theme'] });
      })();
    </script>

    <script>
      // 코드블록 복사 버튼 (Mermaid 다이어그램은 제외)
      document.querySelectorAll<HTMLElement>('.prose pre:not(.mermaid)').forEach((pre) => {
        const wrap = document.createElement('div');
        wrap.className = 'code-wrap';
        pre.parentNode?.insertBefore(wrap, pre);
        wrap.appendChild(pre);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.textContent = '복사';
        btn.setAttribute('aria-label', '코드 복사');
        wrap.appendChild(btn);

        let timer = 0;
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
          try {
            await navigator.clipboard.writeText(code);
            btn.textContent = '복사됨';
            btn.classList.add('is-done');
          } catch {
            btn.textContent = '실패';
          }
          clearTimeout(timer);
          timer = window.setTimeout(() => { btn.textContent = '복사'; btn.classList.remove('is-done'); }, 1500);
        });
      });
    </script>

    <!-- 방문자 수 집계(GoatCounter) — 쿠키 없이 집계 -->
    <script is:inline data-goatcounter="https://jkim.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

    <!-- 집계된 방문자 수를 푸터에 표시(GoatCounter 설정에서 공개 카운터 허용 필요) -->
    <script is:inline>
      (async () => {
        try {
          const res = await fetch('https://jkim.goatcounter.com/counter/TOTAL.json');
          if (!res.ok) return;
          const data = await res.json();
          const value = data.count_unique ?? data.count;
          if (!value) return;
          const el = document.getElementById('visit-count');
          const box = document.getElementById('visits');
          if (!el || !box) return;
          el.textContent = value;
          box.hidden = false;
        } catch {
          /* 카운터가 비공개거나 네트워크 오류면 조용히 숨김 */
        }
      })();
    </script>
  </body>
</html>
<style is:global>
  :root {
    --bg: #f7f8fa;
    --surface: #ffffff;
    --surface-2: #eef1f6;
    --text: #3c4655;
    --heading: #0b1220;
    --muted: #737d8c;
    --faint: #9aa3b2;
    --border: #e7eaf1;
    --border-strong: #d7dce5;
    --accent: #2563eb;
    --accent-weak: #eef3ff;
    --accent-strong: #1d4ed8;
    --code-bg: #0b1220;
    --code-text: #e6edf7;
    --shadow-sm: 0 1px 2px rgb(11 18 32 / .05);
    --shadow: 0 2px 4px -2px rgb(11 18 32 / .08), 0 18px 40px -22px rgb(11 18 32 / .22);
    --mono: ui-monospace, 'JetBrains Mono', 'SF Mono', 'Cascadia Code', Menlo, Consolas, monospace;
    --r: 18px;
    --r-sm: 10px;
    --content: 43rem;
    --page: 60rem;
    color-scheme: light;
  }
  :root[data-theme='dark'] {
    --bg: #0a0f1a;
    --surface: #101927;
    --surface-2: #172236;
    --text: #c4cddc;
    --heading: #f1f5fb;
    --muted: #808da3;
    --faint: #5d6a80;
    --border: #1c2739;
    --border-strong: #2a3850;
    --accent: #6ea8ff;
    --accent-weak: #13223b;
    --accent-strong: #9cc3ff;
    --code-bg: #070c16;
    --code-text: #dbe6f5;
    --shadow-sm: 0 1px 2px rgb(0 0 0 / .35);
    --shadow: 0 2px 6px -2px rgb(0 0 0 / .5), 0 22px 46px -24px rgb(0 0 0 / .75);
    color-scheme: dark;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Pretendard Variable', Pretendard, 'Apple SD Gothic Neo', 'Noto Sans KR', system-ui, sans-serif;
    font-size: 17px;
    line-height: 1.72;
    color: var(--text);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    letter-spacing: -.006em;
    transition: background-color .3s ease, color .3s ease;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .glow {
    position: fixed;
    inset: -22% 0 auto 0;
    height: 460px;
    background: radial-gradient(52% 100% at 50% 0%, color-mix(in srgb, var(--accent) 15%, transparent), transparent 72%);
    pointer-events: none;
    z-index: 0;
    opacity: .6;
  }

  .site-header, main, footer { width: 100%; max-width: var(--page); margin-inline: auto; padding-inline: 24px; }
  main { flex: 1; padding-block: 44px 88px; position: relative; z-index: 1; }

  .site-header { position: sticky; top: 0; z-index: 20; max-width: 100%; padding-inline: 0;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .site-header .bar { max-width: var(--page); margin-inline: auto; padding: 15px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; color: var(--heading); font-weight: 800; font-size: 1.06rem; letter-spacing: -.02em; }
  .brand-mark { color: var(--accent); flex-shrink: 0; transition: transform .2s ease; }
  .brand:hover .brand-mark { transform: rotate(-6deg) scale(1.05); }
  .nav { display: flex; align-items: center; gap: 10px; }
  .nav-tag { font-family: var(--mono); color: var(--faint); font-size: .74rem; letter-spacing: .01em; }
  .icon-btn { display: inline-grid; place-items: center; width: 38px; height: 38px; border-radius: 10px; border: 1px solid var(--border); background: var(--surface); color: var(--muted); cursor: pointer; text-decoration: none; transition: color .18s ease, border-color .18s ease, background-color .18s ease, transform .18s ease; }
  .icon-btn:hover { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 50%, var(--border)); background: var(--accent-weak); transform: translateY(-1px); }
  .icon-moon { display: none; }
  :root[data-theme='dark'] .icon-sun { display: none; }
  :root[data-theme='dark'] .icon-moon { display: block; }

  footer { border-top: 1px solid var(--border); padding-block: 34px; margin-top: 28px; color: var(--muted); font-size: .88rem; display: flex; align-items: center; justify-content: space-between; gap: 12px; position: relative; z-index: 1; }
  footer a { font-family: var(--mono); color: var(--muted); text-decoration: none; font-size: .8rem; letter-spacing: .04em; }
  footer a:hover { color: var(--accent); }
  .footer-right { display: flex; align-items: center; gap: 14px; }
  .visits { font-family: var(--mono); color: var(--faint); font-size: .78rem; letter-spacing: .02em; }
  .visits b { color: var(--muted); font-weight: 700; }

  a { color: var(--accent); text-decoration-thickness: 1.5px; text-underline-offset: 2px; }
  h1, h2, h3, h4 { color: var(--heading); line-height: 1.28; letter-spacing: -.022em; text-wrap: balance; }
  ::selection { background: color-mix(in srgb, var(--accent) 22%, transparent); }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }

  /* 프로즈(본문) — 정해진 틀 없이 그때그때 쓴 내용에 맞춰 자연스럽게 흐르도록 */
  .prose { color: var(--text); font-size: 1.03rem; }
  .prose > * + * { margin-top: 1.15em; }
  .prose > :first-child { margin-top: 0; }
  .prose p { text-wrap: pretty; }
  .prose h1 { margin-top: 1.6em; font-size: 1.7rem; }
  .prose h2 { margin-top: 2em; font-size: 1.4rem; scroll-margin-top: 84px; }
  .prose h3 { margin-top: 1.6em; font-size: 1.16rem; scroll-margin-top: 84px; }
  .prose h4 { margin-top: 1.4em; font-size: 1rem; color: var(--muted); letter-spacing: .01em; }
  .prose h2 + *, .prose h3 + *, .prose h4 + * { margin-top: .6em; }
  .prose strong { color: var(--heading); font-weight: 700; }
  .prose a { color: var(--accent); text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--accent) 35%, transparent); text-underline-offset: 3px; }
  .prose a:hover { text-decoration-color: var(--accent); }
  .prose ul, .prose ol { padding-left: 1.35em; }
  .prose li + li { margin-top: .4em; }
  .prose li > ul, .prose li > ol { margin-top: .4em; }
  .prose li::marker { color: var(--accent); }
  .prose ul li::marker { color: var(--faint); }
  /* 체크리스트(할 일 목록) */
  .prose li:has(> input[type='checkbox']) { list-style: none; margin-left: -1.35em; padding-left: 0; display: flex; align-items: baseline; gap: .5em; }
  .prose input[type='checkbox'] { width: 1em; height: 1em; accent-color: var(--accent); translate: 0 .12em; }
  .prose img { max-width: 100%; border-radius: var(--r-sm); border: 1px solid var(--border); }
  .prose figure { margin: 1.6em 0; }
  .prose figcaption { margin-top: .6em; text-align: center; font-size: .84rem; color: var(--faint); }
  .prose hr { border: 0; text-align: center; margin: 2.6em 0; }
  .prose hr::before { content: '· · ·'; color: var(--faint); letter-spacing: .5em; font-size: .9rem; }
  .prose > blockquote { font-size: 1.05rem; }
  .prose .figcaption { display: block; margin-top: .6em; text-align: center; font-size: .84rem; color: var(--faint); }

  /* 콜아웃(핵심/팁/주의) */
  .prose .callout { display: flex; gap: 12px; margin: 1.5em 0; padding: 14px 16px; border: 1px solid var(--border); border-left-width: 3px; border-radius: var(--r-sm); background: var(--surface-2); }
  .prose .callout--note { border-left-color: #3b82f6; }
  .prose .callout--tip { border-left-color: #22c55e; }
  .prose .callout--warn { border-left-color: #f59e0b; }
  .prose .callout-icon { flex-shrink: 0; font-size: 1.15rem; line-height: 1.5; }
  .prose .callout-body { min-width: 0; }
  .prose .callout-body > :first-child { margin-top: 0; }
  .prose .callout-body > :last-child { margin-bottom: 0; }
  .prose .callout-body p { margin: .4em 0; }

  /* 접기 토글(복습 질문·심화) */
  .prose .toggle { margin: 1.4em 0; border: 1px solid var(--border); border-radius: var(--r-sm); background: var(--surface); overflow: hidden; }
  .prose .toggle > summary { cursor: pointer; padding: 12px 16px; font-weight: 600; color: var(--heading); list-style: none; display: flex; align-items: center; gap: 9px; transition: color .16s ease; }
  .prose .toggle > summary::-webkit-details-marker { display: none; }
  .prose .toggle > summary::before { content: '▶'; color: var(--faint); font-size: .68em; transition: transform .18s ease; }
  .prose .toggle[open] > summary::before { transform: rotate(90deg); }
  .prose .toggle > summary:hover { color: var(--accent); }
  .prose .toggle-body { padding: 2px 16px 14px; }
  .prose .toggle-body > :first-child { margin-top: 0; }

  /* 표(가로 스크롤 안전) */
  .prose .table-wrap { overflow-x: auto; margin: 1.6em 0; }
  .prose .table-wrap table { margin: 0; }

  /* Mermaid 다이어그램(코드블록 스타일 초기화) */
  .prose pre.mermaid { margin: 1.6em 0; padding: 8px 0; background: transparent; border: 0; box-shadow: none; text-align: center; overflow-x: auto; color: var(--muted); }
  .prose pre.mermaid svg { max-width: 100%; height: auto; }
  /* 코드블록 복사 버튼 */
  .code-wrap { position: relative; }
  .code-wrap > pre { margin: 0; }
  .copy-btn { position: absolute; top: 12px; right: 12px; z-index: 2; padding: 5px 10px; border-radius: 7px; cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--code-text) 22%, transparent);
    background: color-mix(in srgb, var(--code-bg) 82%, var(--code-text) 8%);
    color: var(--code-text); font-family: var(--mono); font-size: .72rem;
    opacity: 0; transition: opacity .16s ease, color .16s ease, border-color .16s ease; }
  .code-wrap:hover .copy-btn, .copy-btn:focus-visible { opacity: 1; }
  .copy-btn:hover { border-color: color-mix(in srgb, var(--code-text) 45%, transparent); }
  .copy-btn.is-done { opacity: 1; color: #4ade80; border-color: #4ade80; }
  @media (hover: none) { .copy-btn { opacity: 1; } }

  code { background: var(--surface-2); border: 1px solid var(--border); border-radius: 6px; padding: .1em .4em; font-family: var(--mono); font-size: .84em; color: var(--heading); }
  pre { margin: 1.5em 0; padding: 20px 22px; overflow-x: auto; border-radius: var(--r); background: var(--code-bg); color: var(--code-text); box-shadow: var(--shadow); border: 1px solid color-mix(in srgb, var(--code-text) 10%, transparent); line-height: 1.62; font-size: .9rem; }
  pre code { background: transparent; border: 0; padding: 0; color: inherit; font-size: .86rem; }
  blockquote { margin: 1.6em 0; padding: 2px 20px; border-left: 2.5px solid var(--accent); color: var(--muted); }
  blockquote p { margin: .6em 0; }
  table { width: 100%; border-collapse: collapse; margin: 1.6em 0; font-size: .94rem; border: 1px solid var(--border); border-radius: var(--r-sm); overflow: hidden; }
  th, td { padding: 11px 15px; border-bottom: 1px solid var(--border); text-align: left; }
  th { background: var(--surface-2); color: var(--heading); font-weight: 700; font-size: .82rem; letter-spacing: .01em; }
  td { font-variant-numeric: tabular-nums; }
  tr:last-child td { border-bottom: 0; }

  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: .01ms !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
  }
  @media (max-width: 560px) {
    .nav-tag { display: none; }
    body { font-size: 16px; }
  }
</style>
