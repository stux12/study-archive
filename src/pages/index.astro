---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categories = [...new Set(posts.map((post) => post.data.category))].sort();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) => a.localeCompare(b, 'ko'));
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const fmt = (date: Date) => date.toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })
  .replace(/\.\s?$/, '').replace(/\.\s?/g, '.');
const pad = (n: number) => String(n).padStart(2, '0');
---
<BaseLayout>
  <section class="hero">
    <p class="eyebrow">// LEARNING LOG</p>
    <h1>새롭게 알게 된 정보를<br />내 것으로 만들기 위해<br />다시 정리하는 공간</h1>
    <blockquote class="hero-quote">
      <p>“나는 아직도 배우고 있다.”</p>
      <cite>미켈란젤로</cite>
    </blockquote>
  </section>

  <section aria-labelledby="posts-title">
    <div class="section-heading">
      <h2 id="posts-title">발행한 기록</h2>
      <span class="count" id="post-count">{pad(posts.length)}</span>
    </div>

    <div class="filters" aria-label="학습 기록 필터">
      <label class="search-field">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="post-search" type="search" placeholder="제목·요약으로 검색" />
      </label>
      <div class="chip-row">
        <span class="chip-label">CATEGORY</span>
        <button class="chip is-selected" type="button" data-category="">전체</button>
        {categories.map((category) => <button class="chip" type="button" data-category={category}>{category}</button>)}
      </div>
      {tags.length > 0 && (
        <div class="chip-row">
          <span class="chip-label">TAG</span>
          <button class="chip" type="button" data-tag="">전체</button>
          {tags.map((tag) => <button class="chip" type="button" data-tag={tag}>#{tag}</button>)}
        </div>
      )}
    </div>

    <p id="empty-state" hidden>조건에 맞는 발행 기록이 없습니다.</p>

    <div class="post-list" aria-live="polite">
      {posts.map((post) => (
        <article data-post data-category={post.data.category} data-tags={post.data.tags.join('|')} data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`}>
          <a class="card-link" href={`${baseUrl}posts/${post.id}/`} aria-label={post.data.title}></a>
          <div class="card-top">
            <span class="cat">{post.data.category}</span>
            <span class="sep">/</span>
            <time class="date">{fmt(post.data.date)}</time>
          </div>
          <h3>{post.data.title}</h3>
          {post.data.description && <p class="desc">{post.data.description}</p>}
          {post.data.tags.length > 0 && (
            <div class="tags">{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}</div>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const search = document.querySelector<HTMLInputElement>('#post-search');
  const count = document.querySelector<HTMLElement>('#post-count');
  const empty = document.querySelector<HTMLElement>('#empty-state');
  const posts = [...document.querySelectorAll<HTMLElement>('[data-post]')];
  let category = '';
  let tag = '';

  const update = () => {
    const keyword = search?.value.trim().toLowerCase() ?? '';
    let visible = 0;
    posts.forEach((post) => {
      const matches = (!category || post.dataset.category === category)
        && (!tag || post.dataset.tags?.split('|').includes(tag))
        && (!keyword || post.dataset.search?.toLowerCase().includes(keyword));
      post.hidden = !matches;
      if (matches) visible += 1;
    });
    if (count) count.textContent = String(visible).padStart(2, '0');
    if (empty) empty.hidden = visible > 0;
  };

  document.querySelectorAll<HTMLButtonElement>('[data-category], [data-tag]').forEach((button) => {
    button.addEventListener('click', () => {
      if (button.dataset.category !== undefined) {
        category = button.dataset.category;
        document.querySelectorAll('[data-category]').forEach((item) => item.classList.toggle('is-selected', item === button));
      } else {
        tag = button.dataset.tag ?? '';
        document.querySelectorAll('[data-tag]').forEach((item) => item.classList.toggle('is-selected', item === button));
      }
      update();
    });
  });
  search?.addEventListener('input', update);
</script>

<style>
  .hero { padding: 36px 0 56px; max-width: 42rem; }
  .eyebrow { margin: 0 0 16px; font-family: var(--mono); color: var(--accent); font-weight: 600; font-size: .78rem; letter-spacing: .04em; }
  .hero h1 { margin: 0; font-size: clamp(1.95rem, 1.2rem + 2.9vw, 3rem); font-weight: 800; letter-spacing: -.035em; line-height: 1.24; }
  .hero-quote { margin: 28px 0 0; padding: 3px 0 3px 18px; max-width: 33rem; border-left: 2px solid color-mix(in srgb, var(--accent) 50%, var(--border-strong)); }
  .hero-quote p { margin: 0; color: var(--heading); font-size: 1.16rem; line-height: 1.55; font-weight: 500; }
  .hero-quote cite { display: block; margin-top: 9px; font-family: var(--mono); font-style: normal; color: var(--muted); font-size: .78rem; letter-spacing: .02em; }
  .hero-quote cite::before { content: '— '; color: var(--faint); }

  .section-heading { display: flex; align-items: baseline; gap: 12px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .section-heading h2 { margin: 0; font-size: 1.15rem; font-weight: 700; }
  .count { font-family: var(--mono); color: var(--faint); font-size: .92rem; font-variant-numeric: tabular-nums; }

  .filters { display: grid; gap: 14px; margin-bottom: 28px; padding: 18px; border: 1px solid var(--border); border-radius: var(--r); background: var(--surface); box-shadow: var(--shadow-sm); }
  .search-field { display: flex; align-items: center; gap: 10px; padding: 0 14px; border: 1px solid var(--border-strong); border-radius: var(--r-sm); background: var(--bg); color: var(--muted); transition: border-color .18s ease, box-shadow .18s ease; }
  .search-field:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-weak); }
  .search-field input { flex: 1; border: 0; background: transparent; padding: 11px 0; font: inherit; color: var(--text); outline: none; }
  .chip-row { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .chip-label { min-width: 66px; font-family: var(--mono); color: var(--faint); font-size: .68rem; letter-spacing: .08em; }
  .chip { border: 1px solid var(--border-strong); border-radius: 8px; padding: 6px 12px; color: var(--text); background: var(--surface); font: inherit; font-size: .84rem; font-weight: 500; cursor: pointer; transition: all .16s ease; }
  .chip:hover { border-color: color-mix(in srgb, var(--accent) 45%, var(--border-strong)); color: var(--accent); }
  .chip.is-selected { border-color: transparent; color: #fff; background: var(--accent); font-weight: 600; }
  :root[data-theme='dark'] .chip.is-selected { color: #0a0f1a; }

  #empty-state { margin: 44px 0; color: var(--muted); text-align: center; }

  .post-list { display: grid; gap: 12px; }
  article { position: relative; padding: 24px 28px; border: 1px solid var(--border); border-radius: var(--r); background: var(--surface); box-shadow: var(--shadow-sm); transition: transform .2s ease, box-shadow .24s ease, border-color .2s ease; }
  article:hover { transform: translateY(-2px); box-shadow: var(--shadow); border-color: color-mix(in srgb, var(--accent) 30%, var(--border)); }
  .card-link { position: absolute; inset: 0; z-index: 1; border-radius: var(--r); }
  article::after { content: '→'; position: absolute; top: 22px; right: 24px; color: var(--faint); font-size: 1.05rem; opacity: 0; transform: translateX(-5px); transition: opacity .2s ease, transform .2s ease, color .2s ease; }
  article:hover::after { opacity: 1; transform: none; color: var(--accent); }

  .card-top { display: flex; align-items: center; gap: 8px; margin-bottom: 11px; font-family: var(--mono); font-size: .74rem; letter-spacing: .01em; }
  .cat { color: var(--accent); font-weight: 600; }
  .sep { color: var(--faint); }
  .date { color: var(--muted); font-variant-numeric: tabular-nums; }
  article h3 { margin: 0; font-size: 1.28rem; font-weight: 700; padding-right: 24px; transition: color .18s ease; }
  article:hover h3 { color: var(--accent); }
  .desc { margin: 9px 0 0; color: var(--muted); line-height: 1.6; text-wrap: pretty; }
  .tags { position: relative; z-index: 2; margin-top: 15px; display: flex; flex-wrap: wrap; gap: 10px; width: fit-content; }
  .tag { font-family: var(--mono); color: var(--faint); font-size: .74rem; }
  .tag:hover { color: var(--accent); }

  @media (max-width: 560px) {
    article { padding: 20px; }
    .chip-label { min-width: auto; width: 100%; }
  }
</style>
