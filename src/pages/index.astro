---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categories = [...new Set(posts.map((post) => post.data.category))].sort();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) => a.localeCompare(b, 'ko'));
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout>
  <section class="hero">
    <p class="eyebrow">LEARNING LOG</p>
    <h1>배운 것을 내 언어로<br />다시 정리하는 공간</h1>
    <p>AI 초안을 직접 검수한 뒤, 원할 때만 공개합니다.</p>
  </section>
  <section aria-labelledby="posts-title">
    <div class="section-heading">
      <h2 id="posts-title">발행한 기록</h2>
      <p id="post-count">총 {posts.length}개</p>
    </div>
    <div class="filters" aria-label="학습 기록 필터">
      <label class="search-field">
        <span>검색</span>
        <input id="post-search" type="search" placeholder="제목·요약으로 검색" />
      </label>
      <div class="filter-group">
        <span>카테고리</span>
        <button class="filter-button is-selected" type="button" data-category="">전체</button>
        {categories.map((category) => <button class="filter-button" type="button" data-category={category}>{category}</button>)}
      </div>
      {tags.length > 0 && (
        <div class="filter-group">
          <span>태그</span>
          <button class="filter-button is-selected" type="button" data-tag="">전체</button>
          {tags.map((tag) => <button class="filter-button" type="button" data-tag={tag}>#{tag}</button>)}
        </div>
      )}
    </div>
    <p id="empty-state" hidden>조건에 맞는 발행 기록이 없습니다.</p>
    <div class="post-list" aria-live="polite">
      {posts.map((post) => (
        <article data-post data-category={post.data.category} data-tags={post.data.tags.join('|')} data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`}>
          <p class="meta">{post.data.category} · {post.data.date.toLocaleDateString('ko-KR')}</p>
          <h3><a href={`${baseUrl}posts/${post.id}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div>{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}</div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
<script>
  const search = document.querySelector<HTMLInputElement>('#post-search');
  const count = document.querySelector<HTMLElement>('#post-count');
  const empty = document.querySelector<HTMLElement>('#empty-state');
  const posts = [...document.querySelectorAll<HTMLElement>('[data-post]')];
  let category = '';
  let tag = '';

  const update = () => {
    const keyword = search?.value.trim().toLowerCase() ?? '';
    let visible = 0;
    posts.forEach((post) => {
      const matches = (!category || post.dataset.category === category)
        && (!tag || post.dataset.tags?.split('|').includes(tag))
        && (!keyword || post.dataset.search?.toLowerCase().includes(keyword));
      post.hidden = !matches;
      if (matches) visible += 1;
    });
    if (count) count.textContent = `총 ${visible}개`;
    if (empty) empty.hidden = visible > 0;
  };

  document.querySelectorAll<HTMLButtonElement>('[data-category], [data-tag]').forEach((button) => {
    button.addEventListener('click', () => {
      if (button.dataset.category !== undefined) {
        category = button.dataset.category;
        document.querySelectorAll('[data-category]').forEach((item) => item.classList.toggle('is-selected', item === button));
      } else {
        tag = button.dataset.tag ?? '';
        document.querySelectorAll('[data-tag]').forEach((item) => item.classList.toggle('is-selected', item === button));
      }
      update();
    });
  });
  search?.addEventListener('input', update);
</script>
<style>
  .hero { padding: 44px 0 64px; }
  .eyebrow, .meta { color: #2563eb; font-weight: 700; font-size: .82rem; letter-spacing: .08em; }
  h1 { margin: 0; font-size: clamp(2.1rem, 5vw, 3.6rem); }
  .hero > p:last-child { color: #64748b; font-size: 1.1rem; }
  .section-heading { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .section-heading p { color: #64748b; font-size: .9rem; }
  .filters { display: grid; gap: 12px; margin: 16px 0 24px; padding: 16px; border: 1px solid #e2e8f0; border-radius: 12px; background: #fff; }
  .search-field, .filter-group { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .search-field span, .filter-group > span { min-width: 58px; color: #475569; font-size: .86rem; font-weight: 700; }
  input { flex: 1 1 220px; border: 1px solid #cbd5e1; border-radius: 8px; padding: 8px 10px; font: inherit; }
  .filter-button { border: 1px solid #cbd5e1; border-radius: 999px; padding: 5px 10px; color: #475569; background: #fff; font: inherit; font-size: .85rem; cursor: pointer; }
  .filter-button:hover, .filter-button.is-selected { border-color: #2563eb; color: #1d4ed8; background: #eff6ff; }
  .post-list { display: grid; gap: 16px; }
  article { padding: 24px; border: 1px solid #e2e8f0; border-radius: 12px; background: white; }
  article h3 { margin: 4px 0; font-size: 1.3rem; }
  article h3 a { color: inherit; text-decoration: none; }
  article p { margin: 8px 0; color: #475569; }
  .tag { margin-right: 8px; color: #64748b; font-size: .85rem; }
  #empty-state { margin: 24px 0; color: #64748b; text-align: center; }
  @media (max-width: 640px) { .section-heading { align-items: flex-start; flex-direction: column; gap: 0; } }
</style>
